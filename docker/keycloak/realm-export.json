{
  "realm": "knowledge",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "sslRequired": "none",
  "roles": {
    "realm": [
      {
        "name": "default-roles-knowledge",
        "description": "Composite role for default realm roles",
        "composite": true,
        "composites": {
          "realm": ["user"]
        }
      },
      {
        "name": "user",
        "description": "Default user role"
      },
      {
        "name": "admin",
        "description": "Administrator role"
      }
    ]
  },
  "defaultRole": {
    "name": "default-roles-knowledge",
    "description": "Composite role for default realm roles",
    "composite": true,
    "composites": {
      "realm": ["user"]
    }
  },
  "clients": [
    {
      "clientId": "knowledge-app",
      "name": "Knowledge Backend",
      "description": "Confidential client for the backend API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "knowledge-app-secret",
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "http://localhost:8000/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:8000",
        "http://localhost:5173"
      ],
      "attributes": {
        "access.token.lifespan": "300",
        "client.session.idle.timeout": "1800"
      }
    },
    {
      "clientId": "knowledge-web",
      "name": "Knowledge Frontend",
      "description": "Public PKCE client for the SPA frontend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:8000/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:8000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "access.token.lifespan": "300",
        "client.session.idle.timeout": "1800"
      }
    }
  ],
  "users": [
    {
      "username": "test@knowledge.local",
      "email": "test@knowledge.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "test123",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-knowledge", "user"]
    }
  ]
}
