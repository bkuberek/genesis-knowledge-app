# Environment
ENV_FOR_DYNACONF=development

# Database (matches docker-compose.yml defaults)
KNOWLEDGE_DATABASE__HOST=localhost
KNOWLEDGE_DATABASE__PORT=5432
KNOWLEDGE_DATABASE__NAME=knowledge_db
KNOWLEDGE_DATABASE__USER=knowledge
KNOWLEDGE_DATABASE__PASSWORD=knowledge

# LLM Proxy API
KNOWLEDGE_LLM__API_URL=https://litellm-production-f079.up.railway.app
KNOWLEDGE_LLM__API_KEY=your-api-key-here
KNOWLEDGE_LLM__CHAT_MODEL=anthropic/claude-sonnet-4-20250514
KNOWLEDGE_LLM__EXTRACTION_MODEL=anthropic/claude-sonnet-4-20250514
KNOWLEDGE_LLM__CLASSIFICATION_MODEL=anthropic/claude-haiku-4-20250414

# Also support the legacy env var names from .env
LITE_LLM_PROXY_API_URL=https://litellm-production-f079.up.railway.app
LITE_LLM_PROXY_API_KEY=your-api-key-here

# Keycloak
KNOWLEDGE_KEYCLOAK__SERVER_URL=http://localhost:8080
KNOWLEDGE_KEYCLOAK__REALM=knowledge
KNOWLEDGE_KEYCLOAK__CLIENT_ID=knowledge-app
KNOWLEDGE_KEYCLOAK__CLIENT_SECRET=knowledge-app-secret

# Storage
KNOWLEDGE_STORAGE__DOCUMENT_PATH=data/documents

# Application
KNOWLEDGE_APP_NAME=Knowledge
KNOWLEDGE_DEBUG=true

# ============================================
# Production Deployment (Coolify / docker-compose.kuberek.yml)
