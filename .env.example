# Environment
ENV_FOR_DYNACONF=development

# Database
KNOWLEDGE_DATABASE__HOST=localhost
KNOWLEDGE_DATABASE__PORT=5432
KNOWLEDGE_DATABASE__NAME=knowledge_db
KNOWLEDGE_DATABASE__USER=knowledge
KNOWLEDGE_DATABASE__PASSWORD=knowledge

# LLM Proxy
KNOWLEDGE_LLM__API_URL=https://litellm-production-f079.up.railway.app
KNOWLEDGE_LLM__API_KEY=your-api-key-here

# Keycloak
KNOWLEDGE_KEYCLOAK__SERVER_URL=http://localhost:8080
KNOWLEDGE_KEYCLOAK__REALM=knowledge
KNOWLEDGE_KEYCLOAK__CLIENT_ID=knowledge-app
KNOWLEDGE_KEYCLOAK__CLIENT_SECRET=your-client-secret-here
